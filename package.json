{
  "name": "ragcraft",
  "version": "1.0.0",
  "description": "RAG-enhanced Minecraft agent with memory distillation",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test:embeddings": "node testEmbeddings.js",
    "eval": "node evalRunner.js",
    "eval:clean": "CLEAR_STORE=true node evalRunner.js",
    "analyze": "node analyzeResults.js",
    "visualize": "node visualize.js",
    "plots": "python generate_plots.py",
    "transfer:pipeline": "node transferExperiment.js",
    "eval:batch": "node scripts/runBatchScenarios.js --count 20",
    "eval:batch:10": "node scripts/runBatchScenarios.js --count 10",
    "eval:batch:20": "node scripts/runBatchScenarios.js --count 20",
    "eval:smoke": "node scripts/runBatchScenarios.js --count 1",
    "report:scenarios": "node scripts/buildScenarioReport.js",
    "dashboard:serve": "node scripts/serveDashboard.js",
    "dashboard": "npm run report:scenarios && npm run dashboard:serve",
    "nl:loop": "node scripts/nlCommandLoop.js",
    "run:lever:distilled": "node run.js lever --mode distilled",
    "run:lever:raw": "node run.js lever --mode raw",
    "run:lever:baseline": "npm run run:lever:raw",
    "run:lever:distilled-retrieval": "npm run run:lever:distilled",
    "run:key:distilled": "node run.js key --mode distilled",
    "run:key:raw": "node run.js key --mode raw",
    "run:key:baseline": "npm run run:key:raw",
    "run:key:distilled-retrieval": "npm run run:key:distilled",
    "run:maze:distilled": "node run.js maze --mode distilled",
    "run:maze:raw": "node run.js maze --mode raw",
    "run:maze:baseline": "npm run run:maze:raw",
    "run:maze:distilled-retrieval": "npm run run:maze:distilled",
    "demo:lr": "node run.js lever --mode raw",
    "demo:ld": "node run.js lever --mode distilled",
    "demo:mr": "node run.js maze --mode raw",
    "demo:md": "node run.js maze --mode distilled",
    "demo:kr": "node run.js key --mode raw",
    "demo:kd": "node run.js key --mode distilled",
    "run:all:distilled": "node run.js lever --mode distilled && node run.js key --mode distilled && node run.js maze --mode distilled",
    "run:all:raw": "node run.js lever --mode raw && node run.js key --mode raw && node run.js maze --mode raw",
    "run:all:baseline": "npm run run:all:raw",
    "run:all:distilled-retrieval": "npm run run:all:distilled",
    "run:all:both": "npm run run:all:distilled && npm run run:all:raw"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "minecraft-protocol": "^1.62.0",
    "mineflayer": "^4.33.0",
    "mineflayer-pathfinder": "^2.4.5",
    "uuid": "^13.0.0",
    "vec3": "^0.1.10"
  },
  "devDependencies": {
    "cli-chart": "^0.3.1"
  }
}
